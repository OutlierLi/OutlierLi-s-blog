---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Hr from "@components/Hr.astro";
import Card from "@components/Card";
import Socials from "@components/Socials.astro";
import getAllPosts from "@utils/getAllPosts";
import getSortedPosts from "@utils/getSortedPosts";
import getPostsForSection from "@utils/getPostsForSection";
import { CONTENT_SECTIONS } from "../data/contentSections";
import { SITE, SOCIALS } from "@config";

const posts = await getAllPosts(({ data }) => !data.draft);
const sortedPosts = getSortedPosts(posts);
const latestPosts = sortedPosts.slice(0, 5);
const socialCount = SOCIALS.filter(social => social.active).length;

const sectionStats = CONTENT_SECTIONS.map(section => ({
  ...section,
  count: getPostsForSection(posts, section.key).length,
}));

const focusAreas = [
  "AI",
  "software-engineering",
  "photography",
  "reading",
  "film",
  "personal-knowledge",
];
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero">
      <p class="eyebrow">~/outerli</p>
      <h1>OuterLi Blog</h1>
      <p class="hero-copy">
        记录技术文章、摄影、读书、观影和随想。这里先保持克制，把内容结构搭稳，再逐步长出个人风格。
      </p>
      <div class="hero-actions">
        <LinkButton href="/tech/">进入技术文章</LinkButton>
        <LinkButton
          href="/about/"
          className="underline decoration-dashed underline-offset-4 hover:text-skin-accent"
        >
          关于
        </LinkButton>
      </div>
      {
        socialCount > 0 && (
          <div class="social-wrapper">
            <div class="social-links">Links:</div>
            <Socials />
          </div>
        )
      }
    </section>

    <Hr />

    <section class="home-section">
      <div class="section-heading">
        <p>About</p>
        <h2>个人主页入口</h2>
      </div>
      <p>
        这是 OuterLi
        的个人博客首页。当前版本先完成多栏目结构，后续会继续补齐作品、经历、摄影集、书影音记录和长期随想。
      </p>
      <div class="section-action">
        <LinkButton href="/about/">More about me</LinkButton>
      </div>
    </section>

    <section class="home-section">
      <div class="section-heading">
        <p>Channels</p>
        <h2>内容频道</h2>
      </div>
      <div class="section-grid">
        {
          sectionStats.map(section => (
            <a href={section.href} class="section-card">
              <div>
                <span>{section.key}</span>
                <h3>{section.title}</h3>
              </div>
              <p>{section.description}</p>
              <strong>{section.count}</strong>
            </a>
          ))
        }
      </div>
    </section>

    {
      latestPosts.length > 0 && (
        <section class="home-section">
          <div class="section-heading">
            <p>Latest</p>
            <h2>最新内容</h2>
          </div>
          <ul>
            {latestPosts.map(({ data, slug }) => (
              <Card href={`/posts/${slug}/`} frontmatter={data} />
            ))}
          </ul>
          <div class="section-action">
            <LinkButton href="/posts/">All posts</LinkButton>
          </div>
        </section>
      )
    }

    <section class="home-section">
      <div class="section-heading">
        <p>Focus</p>
        <h2>当前关注</h2>
      </div>
      <ul class="focus-list">
        {focusAreas.map(area => <li>{area}</li>)}
      </ul>
    </section>

    <section class="home-section stats-section">
      <div>
        <strong>{posts.length}</strong>
        <span>posts</span>
      </div>
      <div>
        <strong>{CONTENT_SECTIONS.length}</strong>
        <span>channels</span>
      </div>
      <div>
        <strong>{SITE.author}</strong>
        <span>author</span>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  #main-content {
    @apply mx-auto w-full max-w-5xl px-4;
  }
  #hero {
    @apply py-10 sm:py-14;
  }
  .eyebrow {
    @apply my-0 text-sm font-semibold uppercase text-skin-accent;
  }
  #hero h1 {
    @apply my-4 text-4xl font-bold sm:text-6xl;
  }
  .hero-copy {
    @apply max-w-2xl text-lg leading-8;
  }
  .hero-actions {
    @apply mt-6 flex flex-wrap items-center gap-4;
  }
  .social-wrapper {
    @apply mt-6 flex flex-col sm:flex-row sm:items-center;
  }
  .social-links {
    @apply mb-1 mr-2 whitespace-nowrap sm:mb-0;
  }
  .home-section {
    @apply py-10;
  }
  .home-section > p {
    @apply max-w-3xl leading-7;
  }
  .section-heading {
    @apply mb-5;
  }
  .section-heading p {
    @apply my-0 text-sm font-semibold uppercase text-skin-accent;
  }
  .section-heading h2 {
    @apply mt-1 text-2xl font-semibold;
  }
  .section-action {
    @apply mt-5;
  }
  .section-grid {
    @apply grid gap-4 sm:grid-cols-2;
  }
  .section-card {
    @apply flex min-h-44 flex-col justify-between rounded border border-skin-line p-4 transition-colors hover:border-skin-accent;
  }
  .section-card span {
    @apply text-sm font-semibold text-skin-accent;
  }
  .section-card h3 {
    @apply mt-2 text-xl font-semibold;
  }
  .section-card p {
    @apply my-4 text-sm leading-6 opacity-80;
  }
  .section-card strong {
    @apply text-2xl;
  }
  .focus-list {
    @apply flex flex-wrap gap-2;
  }
  .focus-list li {
    @apply rounded border border-skin-line px-3 py-1 text-sm;
  }
  .stats-section {
    @apply grid gap-4 sm:grid-cols-3;
  }
  .stats-section div {
    @apply border-l-4 border-skin-accent py-2 pl-4;
  }
  .stats-section strong {
    @apply block text-2xl;
  }
  .stats-section span {
    @apply text-sm opacity-70;
  }
</style>

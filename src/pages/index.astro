---
import { Image } from 'astro:assets'

import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import avatar from '@/assets/avatar.svg'
import { contentSections } from '@/lib/content-sections'
import config from '@/site-config'

export const prerender = true

const latestPosts = sortMDByDate(await getBlogCollection()).slice(0, 5)
const updatedAt = new Intl.DateTimeFormat('zh-CN', {
  dateStyle: 'medium',
  timeStyle: 'short',
  timeZone: 'Asia/Shanghai'
}).format(new Date())

const channels = [
  {
    title: '技术文章',
    href: '/blog',
    description: '长期技术文章、项目复盘、工程实践与工具链记录。',
    tag: 'tech'
  },
  ...Object.values(contentSections).map((section) => ({
    title: section.title,
    href: `/${section.tag === 'film' ? 'films' : section.tag === 'thought' ? 'thoughts' : section.tag}`,
    description: section.description,
    tag: section.tag
  }))
]
---

<PageLayout meta={{ title: 'Home', description: config.description }} highlightColor='#0ea5a4'>
  <main class='flex w-full flex-col gap-y-12'>
    <section class='animate grid gap-8 pt-6 sm:grid-cols-[auto_1fr] sm:items-center sm:pt-10'>
      <Image
        src={avatar}
        alt='OuterLi'
        class='size-28 rounded-2xl border bg-background p-2 shadow-sm'
        loading='eager'
      />
      <div class='max-w-3xl'>
        <p class='mb-2 text-sm font-medium text-muted-foreground'>Personal technology and life notes</p>
        <h1 class='text-4xl font-semibold tracking-normal sm:text-5xl'>{config.title}</h1>
        <p class='mt-4 text-base leading-8 text-muted-foreground sm:text-lg'>
          我是 OuterLi。这里会记录技术文章、摄影、读书、观影和随想，把可复用的经验、阶段性的观察和真实生活片段放在同一个地方。
        </p>
        <div class='mt-6 flex flex-wrap gap-3'>
          <Button title='阅读文章' href='/blog' style='ahead' />
          <Button title='关于我' href='/about' />
        </div>
      </div>
    </section>

    <section class='animate'>
      <h2 class='mb-4 text-2xl font-medium'>栏目</h2>
      <div class='grid gap-3 sm:grid-cols-2 lg:grid-cols-3'>
        {
          channels.map((channel) => (
            <a
              href={channel.href}
              class='rounded-lg border bg-background p-4 no-underline transition-colors hover:bg-muted'
            >
              <div class='flex items-center justify-between gap-3'>
                <h3 class='text-lg font-semibold'>{channel.title}</h3>
                <span class='rounded-full border px-2 py-0.5 text-xs text-muted-foreground'>
                  {channel.tag}
                </span>
              </div>
              <p class='mt-2 text-sm leading-6 text-muted-foreground'>{channel.description}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class='animate'>
      <div class='mb-4 flex items-end justify-between gap-4'>
        <h2 class='text-2xl font-medium'>最新内容</h2>
        <a href='/blog' class='text-sm text-muted-foreground hover:text-primary'>全部文章</a>
      </div>
      {
        latestPosts.length === 0 ? (
          <p class='text-muted-foreground'>初始化完成，新的内容正在准备中。</p>
        ) : (
          <ul class='flex flex-col gap-y-4'>
            {latestPosts.map((post) => (
              <PostPreview {post} detailed />
            ))}
          </ul>
        )
      }
    </section>

    <section class='animate border-t py-5 text-sm text-muted-foreground'>
      Last updated: {updatedAt}
    </section>
  </main>
</PageLayout>

---
import type { CollectionEntry } from 'astro:content'

import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import { contentSections, type SectionKey } from '@/lib/content-sections'

interface Props {
  section: SectionKey
}

const { section } = Astro.props
const current = contentSections[section]
const posts = sortMDByDate(await getBlogCollection()).filter((post: CollectionEntry<'blog'>) =>
  post.data.tags.includes(current.tag)
)
---

<PageLayout meta={{ title: current.title, description: current.description }}>
  <Button title='Back' href='/' style='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-3 mt-6 text-3xl font-medium sm:mt-10'>{current.title}</h1>
      <p class='max-w-2xl text-muted-foreground'>{current.description}</p>
    </div>

    <section class='animate mt-10' id='content'>
      {
        posts.length === 0 ? (
          <p class='text-muted-foreground'>{current.empty}</p>
        ) : (
          <ul class='flex flex-col gap-y-4 text-start'>
            {posts.map((post) => (
              <PostPreview {post} detailed />
            ))}
          </ul>
        )
      }
    </section>
  </main>
</PageLayout>
